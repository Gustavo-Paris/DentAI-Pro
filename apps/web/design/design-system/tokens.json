{
  "source": "tailwind.config.ts",
  "preset": "odonto-ai",
  "css": [
    "@parisgroup-ai/pageshell/theme/tokens.css",
    "@parisgroup-ai/pageshell/theme/presets/odonto-ai.css"
  ],
  "tokens": {
    "colors": {
      "primary": "rgb(var(--color-primary-rgb))",
      "primary-foreground": "var(--color-primary-foreground)",
      "secondary": "rgb(var(--color-secondary-rgb))",
      "secondary-foreground": "var(--color-secondary-foreground)",
      "destructive": "rgb(var(--color-destructive-rgb))",
      "muted": "rgb(var(--color-muted-rgb))",
      "accent": "rgb(var(--color-accent-rgb))",
      "success": "rgb(var(--color-success-rgb))",
      "warning": "rgb(var(--color-warning-rgb))",
      "info": "var(--color-info)",
      "background": "rgb(var(--color-background-rgb))",
      "foreground": "rgb(var(--color-foreground-rgb))",
      "border": "rgb(var(--color-border-rgb))",
      "card": "rgb(var(--color-card-rgb))",
      "surface-bg": "var(--surface-bg)",
      "surface-elevated": "var(--surface-elevated)",
      "text-primary": "var(--text-primary)",
      "text-secondary": "var(--text-secondary)",
      "text-tertiary": "var(--text-tertiary)"
    },
    "fonts": {
      "sans": ["DM Sans", "ui-sans-serif", "system-ui", "sans-serif"],
      "display": ["Plus Jakarta Sans", "DM Sans", "ui-sans-serif", "sans-serif"],
      "mono": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "monospace"]
    },
    "borderRadius": {
      "none": "var(--radius-none)",
      "sm": "var(--radius-sm)",
      "md": "var(--radius-md)",
      "lg": "var(--radius-lg)",
      "xl": "var(--radius-xl)",
      "2xl": "var(--radius-2xl)",
      "full": "var(--radius-full)"
    },
    "shadows": {
      "sm": "var(--shadow-sm)",
      "md": "var(--shadow-md)",
      "lg": "var(--shadow-lg)",
      "xl": "var(--shadow-xl)",
      "card": "var(--shadow-card)",
      "dropdown": "var(--shadow-dropdown)",
      "modal": "var(--shadow-modal)",
      "glow": "var(--shadow-glow-primary)"
    },
    "transitions": {
      "duration": {
        "fast": "var(--duration-fast)",
        "normal": "var(--duration-normal)",
        "slow": "var(--duration-slow)",
        "slower": "var(--duration-slower)"
      },
      "easing": {
        "ease-out": "var(--ease-out)",
        "ease-in-out": "var(--ease-in-out)",
        "bounce": "var(--ease-bounce)"
      }
    }
  }
}
