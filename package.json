{
  "name": "dentai-pro",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "@types/react": "^18.3.18",
      "@types/react-dom": "^18.3.5"
    },
    "patchedDependencies": {}
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "bash -c 'cd apps/web && npx eslint --no-warn-ignored --max-warnings=0 \"$@\"' _",
      "bash -c 'scripts/typecheck-baseline.sh'"
    ],
    "supabase/functions/**/*.ts": [
      "bash -c 'cd supabase/functions && deno check --no-lock \"$@\"' _"
    ]
  },
  "dependencies": {
    "@parisgroup-ai/agent-hub": "^4.9.2"
  }
}
